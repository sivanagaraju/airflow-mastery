# ============================================================
# Environment Variables for Airflow Docker Setup
# ============================================================
# Copy this file to .env and customize values
# ============================================================

# Linux only: Set to your user ID to avoid file permission issues
# Run: echo "AIRFLOW_UID=$(id -u)" > .env
AIRFLOW_UID=50000

# Airflow image tag (pin to specific version for stability)
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.4-python3.11

# Project directory (defaults to current directory)
AIRFLOW_PROJ_DIR=.

# Admin user credentials (change in production!)
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# Additional pip packages (lightweight alternative to Dockerfile)
# Separate multiple packages with spaces
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-http apache-airflow-providers-postgres
